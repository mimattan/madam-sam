# Replicate (FLUX.1 Kontext Pro)
REPLICATE_API_TOKEN=r8_your_token_here

# Anthropic (Claude - prompt sanitization)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
MAX_EDITS_PER_HOUR=20

# Cost Protection
MAX_DAILY_API_CALLS=500
MAX_DAILY_SPEND_CENTS=2000

# File Cleanup
FILE_RETENTION_HOURS=24
MAX_STORED_FILES=500

# Shopify (Storefront Web Components integration)
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
ORDER_IMAGE_BASE_URL=https://your-backend-domain.com